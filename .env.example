SCHEDTALK_DB_HOST=localhost
SCHEDTALK_DB_USER=root
SCHEDTALK_DB_PASSWORD=
SCHEDTALK_DB_NAME=schedtalk_db
SCHEDTALK_SECRET_KEY=replace-with-a-long-random-secret

# Copy this file to .env and replace the password with your Gmail App Password.
SCHEDTALK_MAIL_SERVER=smtp.gmail.com
SCHEDTALK_MAIL_PORT=465
SCHEDTALK_MAIL_USE_SSL=1
SCHEDTALK_MAIL_USERNAME=sched.talk23@gmail.com
SCHEDTALK_MAIL_PASSWORD=PASTE_YOUR_GMAIL_APP_PASSWORD_HERE
SCHEDTALK_CONTACT_RECIPIENT=sched.talk23@gmail.com

# Groq AI chatbot settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth settings
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback
